# Do not edit this file directly. 
# Use the .env file in the root directory of the project to set environment variables.
# Global Environment variables for the ecommerce project.

# Path to the storages directory where all project-related database and media files will be stored.
STORAGES_PATH=path/to/storages/directory


# Postgres database settings for ecommerce project.
POSTGRES_DB=database_name
POSTGRES_USER=database_user
POSTGRES_PASSWORD=database_password


# object storage settings for ecommerce project.
MINIO_ROOT_USER=object_storage_user
MINIO_ROOT_PASSWORD=object_storage_password




